#:import dp kivy.metrics.dp
#:import sp kivy.metrics.sp

<MainLayout>:
    orientation: "vertical"
    padding: dp(15)
    spacing: dp(12)

    canvas.before:
        Color:
            rgba: 0.95, 0.96, 0.98, 1
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "vertical"
        size_hint_y: None
        height: dp(180)
        padding: dp(20)

        canvas.before:
            Color:
                rgba: 0.15, 0.45, 0.85, 1
            RoundedRectangle:
                pos: self.pos
                size: self.size
                radius: [25]

        Label:
            text: "Баланс"
            color: 1, 1, 1, 1
            font_size: sp(28)
        Label:
            text: root.balance_text
            color: 1, 1, 1, 1
            bold: True
            font_size: sp(34)

        Label:
            text: root.spent_text
            color: 1, 1, 1, 0.9
            font_size: sp(16)

    TextInput:
        id: amount_input
        hint_text: "Введите сумму"
        multiline: False
        input_filter: None

        size_hint_y: None
        height: dp(60)

        font_size: sp(20)

    BoxLayout:
        size_hint_y: None
        height: dp(60)
        spacing: dp(8)

        Button:
            text: "Столовая"
            font_size: sp(22)
            background_normal: ""
            background_color: (0.15,0.45,0.85,1) if root.selected_category == "Столовая" else (0.8,0.8,0.8,1)
            on_press: root.set_canteen()

        Button:
            text: "Магазин"
            font_size: sp(22)
            background_normal: ""
            background_color: (0.15,0.45,0.85,1) if root.selected_category == "Магазин" else (0.8,0.8,0.8,1)
            on_press: root.set_shop()

        Button:
            text: "Другое"
            font_size: sp(22)
            background_normal: ""
            background_color: (0.15,0.45,0.85,1) if root.selected_category == "Другое" else (0.8,0.8,0.8,1)
            on_press: root.set_other()

    Label:
        text: root.selected_category
        size_hint_y: None
        height: dp(25)
        color: 0.2, 0.2, 0.2, 1
        font_size: sp(16)

    Button:
        text: "+ Добавить расход"

        size_hint_y: None
        height: dp(65)

        font_size: sp(20)

        background_normal: ""
        background_color: 0.2, 0.7, 0.3, 1

        on_press: root.add_expense()

    Label:
        text: "История"
        size_hint_y: None
        height: dp(30)

        font_size: sp(20)
        bold: True

        color: 0.15, 0.15, 0.15, 1

    ScrollView:

        GridLayout:
            id: history_container

            cols: 1
            spacing: dp(5)

            size_hint_y: None
            height: self.minimum_height
